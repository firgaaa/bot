# ============================================================
# Configuration centralisée - BOT KFC
# ============================================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter .env (déjà dans .gitignore).
# ============================================================

# === Bot Telegram ===
BOT_TOKEN=
ADMIN_ID=0
MODERATOR_ID=0
SELLER_ID=0
# Version de l'application bot (affichée par /version)
APP_VERSION=0.1.8

# Mode test Click&Collect (true/false)
USE_TEST_CLICK_ACCOUNT=false

# Compte test Click&Collect (mode test)
CLICK_TEST_ACCOUNT_ID=
CLICK_TEST_ACCOUNT_TOKEN=

# === Base de données PostgreSQL (partagée bot + API) ===
DATABASE_URL=postgres://user:password@localhost:5432/bot_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bot_db
DB_USER=postgres
DB_PASSWORD=postgres

# === API REST (auth Basic pour /insert, /generate, etc.) ===
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# === API Click & Collect (Flask) ===
CLICK_API_URL=http://localhost:5000
# Compte KFC fixe pour le menu pré-achat (catégories + coûts en points)
KFC_LOYALTY_ACCOUNT_ID=
KFC_LOYALTY_ACCOUNT_TOKEN=

# === API KFC Cartes (utilisée par le bot pour appeler l'API locale) ===
KFC_API_URL=http://localhost:8080
KFC_API_USERNAME=
KFC_API_PASSWORD=
KFC_STORAGE_TABLE=kfc_storage
# Timeout (secondes) pour l'appel à /generate (défaut: 120)
KFC_API_GENERATE_TIMEOUT=120

# === API Rust (serveur) ===
PORT=8080
RUST_LOG=info

# === Optionnel : Token pour dérivation des tokens revendeurs ===
# TOKEN_PUBLIC_SECRET=

# === Limite de découvert sur l'argent (optionnel, défaut 4000) ===
# L'argent (portefeuille) peut devenir négatif jusqu'à -MAX_DECOUVERT_ARGENT via les emprunts (admin/vendeur).
# Les points, eux, ne doivent jamais être négatifs.
# MAX_DECOUVERT_ARGENT=4000

# ============================================================
# Config (sync .env -> table config à chaque lancement de database_up.py)
# Valeurs vides = 0, false ou chaîne vide selon le type
# Valeurs avec espaces : mettre entre guillemets (ex: "Texte avec espaces")
# ============================================================
CONFIG_POINT_MIN=
CONFIG_POINT_MAX=
CONFIG_CARD_MARGIN=
CONFIG_PRIX_CARTE=
CONFIG_PAYMENT_URL=
CONFIG_STAFF_CHANNEL_ID=
CONFIG_STAFF_THREAD_PAYMENT=
CONFIG_STAFF_THREAD_REPORT=
CONFIG_STAFF_THREAD_ENTRETIEN=
CONFIG_STAFF_THREAD_DEMANDE_ACCESS=
CONFIG_EMERGENCY_STOP=
CONFIG_ANNOUNCEMENT_TEXT=
CONFIG_ANNOUNCEMENT_PHOTO=
